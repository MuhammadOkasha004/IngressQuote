@using VendorHub.Models.Repositories
@using VendorHub.Models.Classes
@using VendorHub.Services
@page "/vendor/requests"
@layout VendorLayout
@inject InvitationRepository InvitationRepo
@inject AuthStateService AuthState
@inject NavigationManager NavigationManager
@inject ProtectedSessionStorage SessionStorage

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 style="color:var(--text-primary);font-weight:700;margin:0;">
        <span class="bi bi-inbox me-2" style="color:var(--accent);"></span>My Requests / Inbox
    </h3>
    <button class="btn btn-sm btn-secondary" @onclick="LoadAssignments">
        <span class="bi bi-arrow-clockwise"></span> Refresh
    </button>
</div>

@if (isLoading)
{
    <div style="color:#14B8A6;text-align:center;padding:40px;">
        Loading your requests...
    </div>
}
else if (viewingDetail && selectedAssignment != null)
{
    <button class="btn btn-sm btn-secondary mb-3" @onclick="CloseDetail">
        <span class="bi bi-arrow-left"></span> Back to Inbox
    </button>

    <div class="card p-4 mb-4">
        <h5 style="color:var(--text-primary);font-weight:600;margin-bottom:0.5rem;">
            @(selectedAssignment.QuotationRequest?.Title ?? $"Request #{selectedAssignment.QuotationRequestId}")
        </h5>
        <p style="color:var(--text-muted);font-size:0.9rem;margin:0;">
            @(selectedAssignment.QuotationRequest?.Description ?? "")
        </p>
        @if (selectedAssignment.QuotationRequest?.Budget.HasValue == true)
        {
            <p style="color:var(--accent);font-size:0.9rem;margin-top:8px;">
                Budget: <strong>$@selectedAssignment.QuotationRequest.Budget:N2</strong>
            </p>
        }
        @if (selectedAssignment.QuotationRequest?.Deadline.HasValue == true)
        {
            <p style="color:var(--text-muted);font-size:0.85rem;margin-top:4px;">
                Deadline: <strong style="color:var(--text-primary);">@selectedAssignment.QuotationRequest.Deadline.Value.ToString("MMM dd, yyyy")</strong>
            </p>
        }
    </div>

    @if (existingResponse != null)
    {
        <div class="card p-4">
            <h5 style="color:var(--text-primary);font-weight:600;margin-bottom:1rem;">
                <span class="bi bi-check-circle" style="color:var(--accent);"></span> Your Response (Submitted)
            </h5>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div>
                    <div style="color:var(--text-muted);font-size:0.8rem;">Price</div>
                    <div style="color:var(--accent);font-size:1.2rem;font-weight:700;">$@existingResponse.Price.ToString("F2")</div>
                </div>
                <div>
                    <div style="color:var(--text-muted);font-size:0.8rem;">Delivery Days</div>
                    <div style="color:var(--text-primary);font-size:1.2rem;font-weight:600;">@existingResponse.DeliveryDays</div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(existingResponse.Notes))
            {
                <div style="margin-top:12px;">
                    <div style="color:var(--text-muted);font-size:0.8rem;">Notes</div>
                    <div style="color:var(--text-primary);">@existingResponse.Notes</div>
                </div>
            }
            <div style="margin-top:12px;">
                <div style="color:var(--text-muted);font-size:0.8rem;">Submitted</div>
                <div style="color:var(--text-primary);">@existingResponse.SubmittedAt.ToString("MMM dd, yyyy h:mm tt")</div>
            </div>
            <div style="margin-top:12px;">
                <span class="badge badge-@existingResponse.Status.ToLower()">@existingResponse.Status</span>
            </div>
        </div>
    }
    else
    {
        <div class="card p-4">
            <h5 style="color:var(--text-primary);font-weight:600;margin-bottom:1rem;">Submit Your Quote</h5>
            <div class="mb-3">
                <label class="form-label">Price ($)</label>
                <input class="form-control" type="number" step="0.01" @bind="price" />
            </div>
            <div class="mb-3">
                <label class="form-label">Delivery Days</label>
                <input class="form-control" type="number" @bind="deliveryDays" />
            </div>
            <div class="mb-3">
                <label class="form-label">Notes / Remarks</label>
                <textarea class="form-control" rows="3" @bind="notes" placeholder="Optional"></textarea>
            </div>
            <button class="btn btn-primary" @onclick="SubmitResponse" disabled="@isSubmitting">
                @(isSubmitting ? "Submitting..." : "Submit Quote")
            </button>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="color:#FCA5A5;padding:10px;margin-top:10px;background:#7F1D1D;border-radius:8px;text-align:center;">
                    @errorMessage
                </div>
            }
        </div>
    }
}
else if (assignments == null || !assignments.Any())
{
    <div style="text-align:center;padding:3rem;color:var(--text-muted);">
        No quotation requests assigned to your account yet.
    </div>
}
else
{
    <table class="table-custom">
        <thead>
            <tr>
                <th>Quotation Title</th>
                <th>Company / Admin</th>
                <th>Deadline</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in assignments)
            {
                <tr>
                    <td style="font-weight:600;">@(a.QuotationRequest?.Title ?? $"Request #{a.QuotationRequestId}")</td>
                    <td>Admin</td>
                    <td>@(a.QuotationRequest?.Deadline?.ToString("MMM dd, yyyy") ?? "—")</td>
                    <td>
                        <span class="badge badge-@a.Status.ToLower()">@a.Status</span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="() => ShowDetail(a)">
                            <span class="bi bi-eye"></span> View
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<QuotationAssignment> assignments = new();
    private bool isLoading = true;
    private bool viewingDetail = false;
    private QuotationAssignment? selectedAssignment;
    private VendorResponse? existingResponse;
    private decimal price;
    private int deliveryDays = 7;
    private string notes = "";
    private bool isSubmitting = false;
    private string errorMessage = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                if (!AuthState.IsLoggedIn)
                {
                    var roleResult = await SessionStorage.GetAsync<string>("UserRole");
                    if (!roleResult.Success || string.IsNullOrEmpty(roleResult.Value))
                    {
                        NavigationManager.NavigateTo("/login", forceLoad: true);
                        return;
                    }
                    var idResult = await SessionStorage.GetAsync<string>("UserId");
                    var nameResult = await SessionStorage.GetAsync<string>("UserName");
                    var emailResult = await SessionStorage.GetAsync<string>("UserEmail");
                    int restoredVendorId = 0;
                    var vendorIdResult = await SessionStorage.GetAsync<string>("VendorId");
                    if (vendorIdResult.Success && int.TryParse(vendorIdResult.Value, out var vid))
                        restoredVendorId = vid;

                    AuthState.SetUser(
                        idResult.Success ? idResult.Value ?? "" : "",
                        nameResult.Success ? nameResult.Value ?? "" : "",
                        roleResult.Value ?? "",
                        emailResult.Success ? emailResult.Value ?? "" : "",
                        1,
                        restoredVendorId
                    );
                }

                if (AuthState.UserRole != "Vendor")
                {
                    NavigationManager.NavigateTo("/login", forceLoad: true);
                    return;
                }

                if (AuthState.VendorId > 0)
                {
                    await LoadAssignments();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"REQUESTS ERROR: {ex.Message}");
            }
            finally
            {
                isLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadAssignments()
    {
        try
        {
            assignments = await InvitationRepo.GetAssignmentsByVendorAsync(AuthState.VendorId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"LOAD ASSIGNMENTS ERROR: {ex.Message}");
            assignments = new List<QuotationAssignment>();
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task ShowDetail(QuotationAssignment assignment)
    {
        selectedAssignment = assignment;
        existingResponse = null;
        price = 0;
        deliveryDays = 7;
        notes = "";
        errorMessage = "";

        try
        {
            var full = await InvitationRepo.GetAssignmentByIdAsync(assignment.Id);
            if (full != null)
            {
                selectedAssignment = full;
                existingResponse = await InvitationRepo.GetResponseByAssignmentAsync(assignment.Id);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"DETAIL ERROR: {ex.Message}");
        }

        viewingDetail = true;
        StateHasChanged();
    }

    private void CloseDetail()
    {
        viewingDetail = false;
        selectedAssignment = null;
        existingResponse = null;
        StateHasChanged();
    }

    private async Task SubmitResponse()
    {
        if (selectedAssignment == null || price <= 0 || deliveryDays <= 0)
        {
            errorMessage = "Price and delivery days are required.";
            return;
        }

        isSubmitting = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            var response = new VendorResponse
            {
                QuotationAssignmentId = selectedAssignment.Id,
                VendorId = AuthState.VendorId,
                QuotationRequestId = selectedAssignment.QuotationRequestId,
                Price = price,
                DeliveryDays = deliveryDays,
                Notes = string.IsNullOrWhiteSpace(notes) ? null : notes,
                SubmittedAt = DateTime.UtcNow,
                Status = "Submitted"
            };

            await InvitationRepo.CreateResponseAsync(response);
            await InvitationRepo.UpdateAssignmentStatusAsync(selectedAssignment.Id, "Responded");

            existingResponse = response;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SUBMIT ERROR: {ex.Message}");
            errorMessage = "Error submitting response.";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }
}