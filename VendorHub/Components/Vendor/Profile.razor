@using VendorHub.Models.Repositories
@using VendorHub.Services
@page "/vendor/profile"
@layout VendorLayout
@inject AuthStateService AuthState
@inject NavigationManager NavigationManager
@inject ProtectedSessionStorage SessionStorage
@inject ProfileRepository ProfileRepo

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 style="color:var(--text-primary);font-weight:700;margin:0;">
        <span class="bi bi-person me-2" style="color:var(--accent);"></span>Profile Settings
    </h3>
</div>

<div class="card p-4 mb-4" style="max-width:600px;">
    <h5 style="color:var(--text-primary);font-weight:600;margin-bottom:1rem;">Account Information</h5>
    <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input class="form-control" @bind="fullName" />
    </div>
    <div class="mb-3">
        <label class="form-label">Email</label>
        <input class="form-control" @bind="email" readonly style="opacity:0.7;" />
    </div>
    <div class="mb-3">
        <label class="form-label">Company Name</label>
        <input class="form-control" @bind="companyName" />
    </div>
    <div class="mb-3">
        <label class="form-label">Phone</label>
        <input class="form-control" @bind="phone" />
    </div>
    <button class="btn btn-primary" @onclick="SaveProfile">Save Changes</button>
    @if (!string.IsNullOrEmpty(saveMessage))
    {
        <div class="mt-3" style="color:var(--accent);">@saveMessage</div>
    }
</div>

<div class="card p-4" style="max-width:600px;">
    <h5 style="color:var(--text-primary);font-weight:600;margin-bottom:1rem;">Change Password</h5>
    <div class="mb-3">
        <label class="form-label">Current Password</label>
        <input class="form-control" type="password" @bind="currentPassword" />
    </div>
    <div class="mb-3">
        <label class="form-label">New Password</label>
        <input class="form-control" type="password" @bind="newPassword" />
    </div>
    <div class="mb-3">
        <label class="form-label">Confirm New Password</label>
        <input class="form-control" type="password" @bind="confirmPassword" />
    </div>
    <button class="btn btn-primary" @onclick="ChangePassword" disabled="@isLoading">@(isLoading ? "Updating..." : "Update Password")</button>
    @if (!string.IsNullOrEmpty(pwdMessage))
    {
        <div class="mt-3" style="color:@(isPwdError ? "var(--danger)" : "var(--accent)");">@pwdMessage</div>
    }
</div>

@code {
    private string fullName = "";
    private string email = "";
    private string companyName = "";
    private string phone = "";
    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string saveMessage = "";
    private string pwdMessage = "";
    private bool isPwdError = false;
    private bool isLoading = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!AuthState.IsLoggedIn)
            {
                var roleResult = await SessionStorage.GetAsync<string>("UserRole");
                if (!roleResult.Success || string.IsNullOrEmpty(roleResult.Value))
                {
                    NavigationManager.NavigateTo("/login", forceLoad: true);
                    return;
                }
                var idResult = await SessionStorage.GetAsync<string>("UserId");
                var nameResult = await SessionStorage.GetAsync<string>("UserName");
                var emailResult = await SessionStorage.GetAsync<string>("UserEmail");
                int restoredVendorId = 0;
                var vendorIdResult = await SessionStorage.GetAsync<string>("VendorId");
                if (vendorIdResult.Success && int.TryParse(vendorIdResult.Value, out var vid))
                    restoredVendorId = vid;

                AuthState.SetUser(
                    idResult.Success ? idResult.Value ?? "" : "",
                    nameResult.Success ? nameResult.Value ?? "" : "",
                    roleResult.Value ?? "",
                    emailResult.Success ? emailResult.Value ?? "" : "",
                    1,
                    restoredVendorId
                );
            }

            fullName = AuthState.UserName;
            email = AuthState.UserEmail;
            StateHasChanged();
        }
    }

    private async Task SaveProfile()
    {
        saveMessage = "Profile updated successfully.";
    }

    private async Task ChangePassword()
    {
        isLoading = true;
        pwdMessage = "";
        try
        {
            if (newPassword != confirmPassword)
            {
                isPwdError = true;
                pwdMessage = "Passwords do not match.";
                return;
            }
            if (newPassword.Length < 6)
            {
                isPwdError = true;
                pwdMessage = "Password must be at least 6 characters.";
                return;
            }
            var hashed = BCrypt.Net.BCrypt.HashPassword(newPassword);
            var result = ProfileRepo.UpdatePassword(email, hashed);
            if (result)
            {
                isPwdError = false;
                pwdMessage = "Password updated successfully.";
                currentPassword = "";
                newPassword = "";
                confirmPassword = "";
            }
            else
            {
                isPwdError = true;
                pwdMessage = "Failed to update password.";
            }
        }
        catch
        {
            isPwdError = true;
            pwdMessage = "An error occurred.";
        }
        finally { isLoading = false; }
    }
}
