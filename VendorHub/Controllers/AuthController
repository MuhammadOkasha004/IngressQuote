using Microsoft.AspNetCore.Mvc;
using VendorHub.Models.Repositories;

namespace VendorHub.Controllers
{
    [ApiController]
    [Route("api/[controller]")]
    public class AuthController : ControllerBase
    {
        private readonly AuthRepository _authRepository;

        public AuthController(AuthRepository authRepository)
        {
            _authRepository = authRepository;
        }

        [HttpPost("register")]
        public async Task<IActionResult> Register([FromQuery] string username, [FromQuery] string email,
            [FromQuery] string password, [FromQuery] int companyId)
        {
            try
            {
                bool isRegistered = await _authRepository.RegisterAsync(username, email, password, "Admin");
                if (!isRegistered)
                    return BadRequest(new { message = "Email already registered!" });
                return Ok(new { message = "Admin registered successfully!" });
            }
            catch (Exception ex)
            {
                return StatusCode(500, new { message = ex.Message });
            }
        }

        [HttpPost("login")]
        public IActionResult Login([FromQuery] string email, [FromQuery] string password)
        {
            var result = _authRepository.Login(email, password);
            if (result == null)
                return Unauthorized(new { message = "Invalid email or password!" });
            return Ok(result);
        }

        [HttpPost("GenerateInvitationToken")]
        public IActionResult GenerateInvitationToken([FromQuery] string email, [FromQuery] int vendorId)
        {
            try
            {
                string token = _authRepository.GenerateInvitationToken(email, vendorId);
                string invitationLink = $"{Request.Scheme}://{Request.Host}/vendor-register?token={token}";
                return Ok(new { success = true, token, link = invitationLink });
            }
            catch (Exception ex)
            {
                return StatusCode(500, new { success = false, message = ex.Message });
            }
        }

        [HttpGet("VerifyInvitationToken")]
        public IActionResult VerifyInvitationToken([FromQuery] string token)
        {
            if (string.IsNullOrEmpty(token))
                return BadRequest(new { valid = false, message = "Token is required." });
            bool isValid = _authRepository.VerifyInvitationToken(token);
            if (isValid)
                return Ok(new { valid = true, message = "Token is valid." });
            return BadRequest(new { valid = false, message = "Token is invalid or expired." });
        }

        [HttpPost("RegisterVendor")]
        public IActionResult RegisterVendor([FromQuery] string token, [FromQuery] string password)
        {
            if (string.IsNullOrEmpty(token) || string.IsNullOrEmpty(password))
                return BadRequest(new { success = false, message = "Token and password are required." });
            try
            {
                bool isRegistered = _authRepository.RegisterVendor(token, password);
                if (isRegistered)
                    return Ok(new { success = true, message = "Vendor registered successfully." });
                return BadRequest(new { success = false, message = "Registration failed. Invalid or expired token." });
            }
            catch (Exception ex)
            {
                return StatusCode(500, new { success = false, message = ex.Message });
            }
        }
    }
}
