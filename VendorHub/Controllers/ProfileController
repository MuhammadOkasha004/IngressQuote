using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using System;
using VendorHub.Models.Repositories;

namespace VendorHub.Controllers
{
    [Authorize]
    [ApiController]
    [Route("api/[controller]")]
    public class ProfileController : ControllerBase
    {
        private readonly ProfileRepository _profileRepo = new ProfileRepository();

        [HttpGet("GetProfile")]
        public IActionResult GetProfile([FromQuery] string email)
        {
            try
            {
                var userProfile = _profileRepo.GetUserProfile(email);
                if (userProfile == null)
                {
                    return NotFound(new { success = false, message = "User not found." });
                }
                return Ok(userProfile);
            }
            catch (Exception ex)
            {
                return StatusCode(500, new { success = false, error = ex.Message });
            }
        }

        [HttpPost("ChangePassword")]
        public IActionResult ChangePassword([FromQuery] string email, [FromQuery] string newPassword)
        {
            try
            {
                string hashedPassword = BCrypt.Net.BCrypt.HashPassword(newPassword);
                bool updated = _profileRepo.UpdatePassword(email, hashedPassword);
                if (updated)
                {
                    return Ok(new { success = true, message = "Password updated successfully." });
                }
                return BadRequest(new { success = false, message = "Failed to update password." });
            }
            catch (Exception ex)
            {
                return StatusCode(500, new { success = false, error = ex.Message });
            }
        }
    }
}